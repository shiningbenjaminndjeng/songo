{
  "version": 2,
  "name": "songo-game",
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/online",     "destination": "/online.html" },
    { "source": "/",           "destination": "/index.html" }
  ],
  "functions": {
    "api/*.js": { "memory": 128, "maxDuration": 10 }
  }
}
