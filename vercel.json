{
  "version": 2,
  "name": "songo-game",
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/online",   "dest": "/public/online.html" },
    { "src": "/",         "dest": "/public/index.html" },
    { "src": "/(.*)",     "dest": "/public/$1" }
  ],
  "functions": {
    "api/*.js": { "memory": 128, "maxDuration": 10 }
  }
}
