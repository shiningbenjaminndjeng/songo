{
  "version": 2,
  "name": "songo-game",
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/online",   "dest": "/public/online.html" },
    { "src": "/",         "dest": "/public/index.html" },
    { "src": "/(.*)",     "dest": "/public/$1" }
  ]
}
